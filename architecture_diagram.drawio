        <!-- f11: p6 (exit bottom-left 25%) → y=656 corridor → left margin (x=80) → n_rest left side
             f12: p6 (exit bottom-right 75%) → y=668 corridor → x=565 (gap between n_mcp & n_saia) → n_hec left side
             Both horizontal runs stay above Splunk components (n_mcp/n_saia/n_hec top = y=672). -->
        <mxCell id="f11" value="deploy detection" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#3E8E2E;strokeWidth=1.5;fontSize=10;fontColor=#173E0F;labelBackgroundColor=#ffffff;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p6" target="n_rest">
