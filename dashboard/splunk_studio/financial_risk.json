{
  "title": "DetectForge \u2014 Financial Risk (FAIR Model)",
  "description": "Detection gaps translated into annual dollar risk \u2014 prioritise by exposure",
  "defaultInputs": {},
  "layout": {
    "type": "grid",
    "options": {},
    "structure": [
      {
        "item": "viz_total",
        "type": "block",
        "position": {
          "x": 0,
          "y": 0,
          "w": 390,
          "h": 150
        }
      },
      {
        "item": "viz_removable",
        "type": "block",
        "position": {
          "x": 400,
          "y": 0,
          "w": 390,
          "h": 150
        }
      },
      {
        "item": "viz_datagap",
        "type": "block",
        "position": {
          "x": 800,
          "y": 0,
          "w": 395,
          "h": 150
        }
      },
      {
        "item": "viz_top10",
        "type": "block",
        "position": {
          "x": 0,
          "y": 170,
          "w": 715,
          "h": 430
        }
      },
      {
        "item": "viz_tactic",
        "type": "block",
        "position": {
          "x": 725,
          "y": 170,
          "w": 470,
          "h": 430
        }
      },
      {
        "item": "viz_method",
        "type": "block",
        "position": {
          "x": 0,
          "y": 620,
          "w": 1195,
          "h": 150
        }
      }
    ],
    "globalInputs": []
  },
  "dataSources": {
    "ds_top10": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_gaps.csv | where status!=\"CLOSED\" | sort -financial_exposure_usd | head 12 | eval annual_risk=\"$\".tostring(round(financial_exposure_usd,0),\"commas\") | table technique_id,technique_name,tactic,annual_risk",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_tactic": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_gaps.csv | where status!=\"CLOSED\" | stats sum(financial_exposure_usd) as exposure by tactic | eval risk_m=round(exposure/1000000,2) | sort -exposure",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_total": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_gaps.csv | where status!=\"CLOSED\" | eval fe=tonumber(financial_exposure_usd) | stats sum(fe) as total",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_topgap": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_gaps.csv | where status!=\"CLOSED\" | eval fe=tonumber(financial_exposure_usd) | stats max(fe) as top_gap",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_critical": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_gaps.csv | where status!=\"CLOSED\" | eval fe=tonumber(financial_exposure_usd) | stats count(eval(fe>250000)) as critical",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    }
  },
  "visualizations": {
    "viz_total": {
      "type": "splunk.singlevalue",
      "dataSources": {
        "primary": "ds_total"
      },
      "options": {
        "majorField": "total",
        "majorColor": "#e74c3c",
        "unit": "$",
        "unitPosition": "before",
        "backgroundColor": "#16213e",
        "sparklineDisplay": "off",
        "trendDisplay": "off",
        "numberPrecision": "0"
      },
      "title": "Total Annual Risk"
    },
    "viz_removable": {
      "type": "splunk.singlevalue",
      "dataSources": {
        "primary": "ds_topgap"
      },
      "options": {
        "majorField": "top_gap",
        "majorColor": "#f39c12",
        "unit": "$",
        "unitPosition": "before",
        "backgroundColor": "#16213e",
        "sparklineDisplay": "off",
        "trendDisplay": "off",
        "numberPrecision": "0"
      },
      "title": "Most Expensive Blind Spot"
    },
    "viz_datagap": {
      "type": "splunk.singlevalue",
      "dataSources": {
        "primary": "ds_critical"
      },
      "options": {
        "majorField": "critical",
        "majorColor": "#3498db",
        "backgroundColor": "#16213e",
        "sparklineDisplay": "off",
        "trendDisplay": "off",
        "numberPrecision": "0"
      },
      "title": "Critical Gaps (>$250K each)"
    },
    "viz_top10": {
      "type": "splunk.table",
      "dataSources": {
        "primary": "ds_top10"
      },
      "options": {
        "backgroundColor": "#1a1a2e"
      },
      "title": "Top Gaps by Annual $ Risk"
    },
    "viz_tactic": {
      "type": "splunk.bar",
      "dataSources": {
        "primary": "ds_tactic"
      },
      "options": {
        "xField": "tactic",
        "yField": "risk_m",
        "seriesColors": [
          "#e74c3c"
        ],
        "backgroundColor": "#1a1a2e",
        "xAxisLabelRotation": -30,
        "yAxisTitleText": "$M risk"
      },
      "title": "Risk by MITRE Tactic ($M)"
    },
    "viz_method": {
      "type": "splunk.markdown",
      "options": {
        "markdown": "**FAIR model** \u2014 Annual Loss Expectancy = technique frequency (Verizon DBIR 2025) x industry relevance x blast radius x breach cost (IBM Cost of a Data Breach 2025: $9.8M healthcare avg). Estimates for risk-based prioritisation. **Removable Now** = gaps DetectForge can close with existing log data; **Blocked** = gaps that first need new log sources onboarded."
      },
      "title": "Methodology"
    }
  }
}