{
  "title": "DetectForge \u2014 Detection Coverage & Risk",
  "description": "Threat-actor coverage, gaps by MITRE tactic, and financial exposure",
  "defaultInputs": {},
  "layout": {
    "type": "grid",
    "options": {},
    "structure": [
      {
        "item": "viz_threat",
        "type": "block",
        "position": {
          "x": 0,
          "y": 0,
          "w": 290,
          "h": 150
        }
      },
      {
        "item": "viz_active",
        "type": "block",
        "position": {
          "x": 300,
          "y": 0,
          "w": 290,
          "h": 150
        }
      },
      {
        "item": "viz_gaps_open",
        "type": "block",
        "position": {
          "x": 600,
          "y": 0,
          "w": 290,
          "h": 150
        }
      },
      {
        "item": "viz_exposure",
        "type": "block",
        "position": {
          "x": 900,
          "y": 0,
          "w": 295,
          "h": 150
        }
      },
      {
        "item": "viz_tactic_cov",
        "type": "block",
        "position": {
          "x": 0,
          "y": 170,
          "w": 1195,
          "h": 330
        }
      },
      {
        "item": "viz_gaps_table",
        "type": "block",
        "position": {
          "x": 0,
          "y": 520,
          "w": 1195,
          "h": 430
        }
      }
    ],
    "globalInputs": []
  },
  "dataSources": {
    "ds_threat": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_actor_chains.csv | stats first(coverage_pct) as c by actor | stats avg(c) as threat_coverage | eval threat_coverage=round(threat_coverage,0)",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_active": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_rules.csv | stats count(eval(status=\"DEPLOYED\")) as active",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_gapcount": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_gaps.csv | where status!=\"CLOSED\" | stats count as open_gaps",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_exposure": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_gaps.csv | where status!=\"CLOSED\" | stats sum(financial_exposure_usd) as financial_exposure_usd",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_tactic": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_tactic_coverage.csv | sort coverage_pct | table tactic coverage_pct",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    },
    "ds_gaps": {
      "type": "ds.search",
      "options": {
        "query": "| inputlookup detectforge_gaps.csv | where status!=\"CLOSED\" | eval exposure=\"$\".tostring(round(financial_exposure_usd,0),\"commas\") | sort -financial_exposure_usd | head 12 | table technique_id,technique_name,tactic,exposure",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        },
        "refresh": "20s",
        "refreshType": "delay"
      }
    }
  },
  "visualizations": {
    "viz_threat": {
      "type": "splunk.singlevalue",
      "dataSources": {
        "primary": "ds_threat"
      },
      "options": {
        "majorField": "threat_coverage",
        "majorColor": "#2ecc71",
        "backgroundColor": "#16213e",
        "sparklineDisplay": "off",
        "trendDisplay": "off",
        "numberPrecision": "0",
        "unit": "%"
      },
      "title": "Threat-Actor Coverage"
    },
    "viz_active": {
      "type": "splunk.singlevalue",
      "dataSources": {
        "primary": "ds_active"
      },
      "options": {
        "majorField": "active",
        "majorColor": "#3498db",
        "backgroundColor": "#16213e",
        "sparklineDisplay": "off",
        "trendDisplay": "off",
        "numberPrecision": "0"
      },
      "title": "Active Detections"
    },
    "viz_gaps_open": {
      "type": "splunk.singlevalue",
      "dataSources": {
        "primary": "ds_gapcount"
      },
      "options": {
        "majorField": "open_gaps",
        "majorColor": "#f39c12",
        "backgroundColor": "#16213e",
        "sparklineDisplay": "off",
        "trendDisplay": "off",
        "numberPrecision": "0"
      },
      "title": "Open Gaps"
    },
    "viz_exposure": {
      "type": "splunk.singlevalue",
      "dataSources": {
        "primary": "ds_exposure"
      },
      "options": {
        "majorField": "financial_exposure_usd",
        "majorColor": "#e74c3c",
        "backgroundColor": "#16213e",
        "sparklineDisplay": "off",
        "trendDisplay": "off",
        "numberPrecision": "0",
        "unit": "$",
        "unitPosition": "before"
      },
      "title": "Annual Risk Exposure"
    },
    "viz_tactic_cov": {
      "type": "splunk.bar",
      "dataSources": {
        "primary": "ds_tactic"
      },
      "options": {
        "xField": "tactic",
        "yField": "coverage_pct",
        "seriesColors": [
          "#2ecc71"
        ],
        "backgroundColor": "#1a1a2e",
        "xAxisLabelRotation": -30,
        "yAxisTitleText": "Coverage %"
      },
      "title": "Coverage by MITRE Tactic (which kill-chain phases are weak)"
    },
    "viz_gaps_table": {
      "type": "splunk.table",
      "dataSources": {
        "primary": "ds_gaps"
      },
      "options": {
        "backgroundColor": "#1a1a2e"
      },
      "title": "Top Undetected Gaps by Annual $ Risk"
    }
  }
}