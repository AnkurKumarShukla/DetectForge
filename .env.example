# Splunk connection
SPLUNK_URL=https://localhost:8089
SPLUNK_TOKEN=your-splunk-token-here
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme
SPLUNK_VERIFY_SSL=false

# Splunk MCP Server
MCP_ENDPOINT=http://localhost:8765
MCP_TOKEN=your-mcp-token-here

# Industry profile: healthcare | finance | energy | technology
INDUSTRY_PROFILE=healthcare

# Together AI — primary LLM (Llama 3.3 70B) + optional fine-tuned model
TOGETHER_API_KEY=your-together-key-here
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Fine-tuned SPL model (optional — activate after running scripts/prepare_finetune_data.py)
# Steps: prepare data → upload to Together AI → fine-tune → set model ID below
# FINETUNED_MODEL_ID=your-account/foundation-sec-spl-v1
# USE_FINETUNED_SPL=false

# App config
DATABASE_URL=sqlite:///./detectforge.db
LOG_LEVEL=INFO
DRIFT_MONITOR_INTERVAL_HOURS=6
MAX_SPL_GENERATION_ATTEMPTS=3
MAX_TUNING_ROUNDS=3
HITS_PER_DAY_GOOD_THRESHOLD=50
HITS_PER_DAY_VERY_NOISY_THRESHOLD=500
CONFIDENCE_MANDATORY_REVIEW_THRESHOLD=0.75
CONFIDENCE_GENERATION_MIN=0.70
